# Beacon - Environment Configuration
# ====================================
# Copy this file to .env and adjust values as needed.
# For Docker: most values below work out-of-the-box.
# For local dev: change hostnames from service names to localhost.

# Database (PostgreSQL 16 with asyncpg)
DATABASE_URL=postgresql+asyncpg://beacon_user:beacon_pass@localhost:5432/beacon_db

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API Key prefix for external connectors
API_KEY_PREFIX=bcn_

# Application
APP_VERSION=0.1.0

# CORS — allowed origins for the frontend
CORS_ORIGINS=["http://localhost:5173"]

# Redis (Cache)
REDIS_URL=redis://localhost:6379/0

# Agent Token prefix (for agent authentication)
AGENT_TOKEN_PREFIX=beacon_agent_

# Fernet key for connection config encryption (32-byte base64 string)
# Leave empty for dev/test to use plaintext storage
FERNET_KEY=

# Email settings
EMAIL_CHECK_DELIVERABILITY=true
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@beacon.app

# Agent token file path (shared volume in Docker)
AGENT_TOKEN_FILE=/run/beacon/agent_token

# Frontend — backend URL for Vite proxy (Docker: http://backend:8000)
VITE_BACKEND_URL=http://localhost:8000
